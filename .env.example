# Create a free key at https://apexlegendsapi.com/
APEX_API_KEY=your_api_key_here

# Optional native Android widget roster.
# Format: PLATFORM:player,PLATFORM:friend_one,PLATFORM:friend_two
# Supported platform values: PC, PS4, X1
DROPZONE_MOBILE_WIDGET_PLAYERS=PS4:blumoat_onyatta,PC:FriendOne,PS4:FriendTwo

# Optional daily reset timezone for server-side native widget RP baselines.
DROPZONE_WIDGET_TIME_ZONE=Africa/Nairobi
