# Create a free key at https://apexlegendsapi.com/
APEX_API_KEY=your_api_key_here

# Optional native Android widget roster.
# Format: PLATFORM:player,PLATFORM:friend_one,PLATFORM:friend_two
# Supported platform values: PC, PS4, X1
DROPZONE_MOBILE_WIDGET_PLAYERS=PS4:blumoat_onyatta,PC:FriendOne,PS4:FriendTwo

# Optional daily reset timezone for server-side native widget RP baselines.
DROPZONE_WIDGET_TIME_ZONE=Africa/Nairobi

# Optional cron protection. Set this in production, then call cron with:
# Authorization: Bearer your_long_random_secret
DROPZONE_CRON_SECRET=your_long_random_secret_here

# Optional RP history storage.
# Local development defaults to .dropzone-data/rp-history.json.
# Production should use Upstash Redis or Vercel KV REST env vars for durable history.
DROPZONE_RP_HISTORY_STORE=file
DROPZONE_RP_HISTORY_FILE=.dropzone-data/rp-history.json
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=
