<?xml version="1.0" encoding="utf-8"?>
<!-- Shared Android styles for the launcher activity and compact Rank Pulse widget. -->
<resources>
    <style name="Theme.Dropzone" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/dropzone_background_end</item>
        <item name="android:statusBarColor">@color/dropzone_background_start</item>
    </style>

    <style name="WidgetHeaderRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">7dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="WidgetHeaderNotch">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">2dp</item>
        <item name="android:layout_marginEnd">7dp</item>
        <item name="android:background">@drawable/widget_header_notch</item>
    </style>

    <style name="WidgetTitleText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.16</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/dropzone_text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetSyncPill">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/widget_status_pill</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/dropzone_pill_text</item>
        <item name="android:textSize">8sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetPlayerRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="WidgetPlayerMainLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="WidgetRankBadge">
        <item name="android:layout_width">27dp</item>
        <item name="android:layout_height">27dp</item>
        <item name="android:background">@drawable/rank_badge_background</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/dropzone_badge_platinum</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetPlayerNameColumn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">7dp</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="WidgetPlayerRole">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/dropzone_text_quiet</item>
        <item name="android:textSize">6sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetPlayerNameLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="WidgetPlayerName">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">@color/dropzone_text_primary</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="WidgetHeatIcon">
        <item name="android:layout_width">15dp</item>
        <item name="android:layout_height">15dp</item>
        <item name="android:layout_marginStart">3dp</item>
        <item name="android:src">@drawable/ic_heat_streak</item>
    </style>

    <style name="WidgetRankText">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/dropzone_text_secondary</item>
        <item name="android:textSize">8sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetRpText">
        <item name="android:layout_width">58dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/dropzone_text_primary</item>
        <item name="android:textSize">8sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetDailyNetText">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">5dp</item>
        <item name="android:background">@drawable/widget_daily_net_neutral</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textColor">@color/dropzone_daily_neutral_text</item>
        <item name="android:textSize">7sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetProgressStack">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:layout_marginStart">34dp</item>
        <item name="android:layout_marginTop">5dp</item>
    </style>

    <style name="WidgetProgressBlue" parent="@android:style/Widget.ProgressBar.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:progressDrawable">@drawable/progress_blue</item>
    </style>

    <style name="WidgetProgressLightGreen" parent="@android:style/Widget.ProgressBar.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:progressDrawable">@drawable/progress_light_green</item>
    </style>

    <style name="WidgetProgressStrongGreen" parent="@android:style/Widget.ProgressBar.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:progressDrawable">@drawable/progress_strong_green</item>
    </style>

    <style name="WidgetProgressLightRed" parent="@android:style/Widget.ProgressBar.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:progressDrawable">@drawable/progress_light_red</item>
    </style>

    <style name="WidgetProgressStrongRed" parent="@android:style/Widget.ProgressBar.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:progressDrawable">@drawable/progress_strong_red</item>
    </style>
</resources>
