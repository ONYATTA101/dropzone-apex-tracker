<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded dark widget card. Android widgets cannot blur like CSS, so this approximates Rank Pulse glass. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <corners android:radius="28dp" />
    <gradient
        android:angle="145"
        android:endColor="@color/dropzone_card_end"
        android:startColor="@color/dropzone_card_start" />
    <stroke
        android:width="1dp"
        android:color="@color/dropzone_border" />
</shape>
